---
import About from "../components/sections/About.astro";
import Contact from "../components/sections/Contact.astro";
import Hero from "../components/sections/Hero.astro";
import ProjectsPreview from "../components/sections/ProjectsPreview.astro";
import Skills from "../components/sections/Skills.astro";
import Footer from "../components/ui/Footer.astro";
import Navbar from "../components/ui/Navbar.astro";
import type { Language } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";
import Layout from "../layouts/Layout.astro";

const lang: Language = "es";
const { t } = await useTranslations(lang);
---

<Layout
  title={t("meta.homeTitle")}
  description={t("meta.homeDescription")}
  ogImage="/assets/logo-lr.png"
  ogImageAlt="Luciano Romero - Portfolio"
  lang={lang}
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />

  <main>
    <Hero lang={lang} />
    <About lang={lang} />
    <Skills lang={lang} />
    <ProjectsPreview lang={lang} />
    <Contact lang={lang} />
  </main>

  <Footer lang={lang} />
</Layout>
