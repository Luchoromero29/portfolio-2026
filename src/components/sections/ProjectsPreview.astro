---
import { getFeaturedProjects } from "../../data/projects";
import type { Language } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";
import Button from "../ui/Button.astro";

export interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const { t } = await useTranslations(lang);
const featuredProjects = getFeaturedProjects();

const accents = [
  { from: "#c8db87", to: "#53b598" },
  { from: "#53b598", to: "#6abda0" },
  { from: "#8eca91", to: "#c8db87" },
];
---

<section id="projects-preview" class="py-32 sm:py-40 bg-white dark:bg-slate-900 relative overflow-hidden">

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Heading -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-16 reveal">
      <div>
        <p class="eyebrow mb-3">{t("projects.subtitle")}</p>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
          <span data-i18n="projects.featured">{t("projects.featured")}</span>
        </h2>
      </div>
      <Button href="/projects" variant="ghost" size="md" class="group shrink-0">
        <span data-i18n="projects.viewAll">{t("projects.viewAll")}</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
    </div>

    <!-- List -->
    <div class="reveal">
      <div class="border-t border-slate-200 dark:border-slate-800"></div>

      {featuredProjects.map((p, idx) => {
        const g = accents[idx % accents.length];
        const num = String(idx + 1).padStart(2, "0");
        const thumb = p.thumbnail || (p.images && p.images[0]) || "";
        return (
          <a
            href={`/projects/${p.slug}`}
            class="proj-row group relative flex flex-col md:flex-row items-stretch md:items-center gap-5 md:gap-8 py-6 md:py-8 border-b border-slate-200 dark:border-slate-800 overflow-hidden"
          >
            <!-- Hover fill -->
            <div
              class="proj-fill absolute inset-0 -translate-x-full transition-transform duration-500 ease-expo pointer-events-none"
              style={`background: linear-gradient(105deg, ${g.from}0d 0%, ${g.to}08 100%);`}
            ></div>
            <!-- Left accent bar -->
            <div
              class="proj-bar absolute left-0 top-0 bottom-0 w-0.75 scale-y-0 transition-transform duration-500 origin-bottom rounded-r pointer-events-none"
              style={`background: linear-gradient(to bottom, ${g.from}, ${g.to});`}
            ></div>

            <!-- Index -->
            <span class="proj-index shrink-0 text-[11px] font-black tracking-[0.18em] text-slate-300 dark:text-slate-700 w-6 select-none pl-2">
              {num}
            </span>

            <!-- Visual preview -->
            <div
              class="proj-thumb-wrap order-1 md:order-2 shrink-0 w-full md:w-60 xl:w-70 h-42.5 md:h-36.25 xl:h-41.25 rounded-2xl overflow-hidden relative"
              style={`--thumb-accent: ${g.to}66;`}
            >
              <!-- Gradient fallback -->
              <div
                class="absolute inset-0"
                style={`background: linear-gradient(135deg, ${g.from}55, ${g.to}55);`}
              ></div>
              {thumb ? (
                <img
                  src={thumb}
                  alt={p.title}
                  class="proj-thumb absolute inset-0 w-full h-full object-contain  opacity-0 transition-all duration-500 scale-100 group-hover:scale-[1.03]"
                  loading="lazy"
                  onload="this.style.opacity='1'"
                  onerror="this.style.display='none'"
                />
              ) : null}

              <!-- Tiny frame caption -->
              <div class="absolute top-2.5 right-2.5 px-2 py-0.5 rounded-md text-[10px] font-bold tracking-wide bg-black/60 text-white/90 border border-white/15">
                PREVIEW
              </div>

              <!-- Subtle overlay on hover -->
              <div
                class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                style={`background: linear-gradient(135deg, ${g.from}20, transparent 45%);`}
              ></div>
            </div>

            <!-- Text content -->
            <div class="flex-1 min-w-0 order-2 md:order-1">
              <h3
                class="proj-title text-xl sm:text-2xl md:text-[26px] font-extrabold tracking-tight text-slate-900 dark:text-white leading-snug mb-1.5 transition-colors duration-200"
                style={`--accent: ${g.to};`}
              >
                <span class="proj-underline" style={`--ul-from: ${g.from}; --ul-to: ${g.to};`}>{p.title}</span>
              </h3>
              <p class="text-[13px] text-slate-500 dark:text-slate-400 leading-relaxed mb-3 line-clamp-1 hidden sm:block">
                {p.shortDescription}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {p.technologies.slice(0, 3).map((tech) => (
                  <span class="px-2 py-0.5 rounded-md text-[11px] font-semibold text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 transition-colors duration-200">
                    {tech}
                  </span>
                ))}
                {p.technologies.length > 3 && (
                  <span class="px-2 py-0.5 rounded-md text-[11px] font-semibold text-slate-400 dark:text-slate-500">
                    +{p.technologies.length - 3}
                  </span>
                )}
              </div>
            </div>

            <!-- Arrow -->
            <div
              class="proj-arrow shrink-0 w-10 h-10 rounded-full border border-slate-200 dark:border-slate-700 flex items-center justify-center transition-all duration-300"
              style={`--afrom: ${g.from}; --ato: ${g.to};`}
            >
              <svg class="w-4 h-4 text-slate-400 transition-all duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Index number floats up */
  .proj-index {
    display: inline-block;
    transition: transform 0.25s ease;
  }
  .proj-row:hover .proj-index {
    transform: translateY(-4px);
  }

  /* Title underline draws left → right */
  .proj-underline {
    background-image: linear-gradient(
      to right,
      var(--ul-from, #53b598),
      var(--ul-to, #c8db87)
    );
    background-size: 0% 1.5px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    padding-bottom: 2px;
    transition: background-size 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .proj-row:hover .proj-underline {
    background-size: 100% 1.5px;
  }

  /* Thumbnail accent border */
  .proj-thumb-wrap {
    transition: box-shadow 0.35s ease, transform 0.35s ease;
    border: 1px solid rgba(148, 163, 184, 0.28);
    background: linear-gradient(165deg, rgba(15, 23, 42, 0.28), rgba(15, 23, 42, 0.42));
  }
  .proj-row:hover .proj-thumb-wrap {
    box-shadow: 0 0 0 2px var(--thumb-accent, rgba(83, 181, 152, 0.4));
    transform: translateY(-2px);
  }

  :global(.dark) .proj-thumb-wrap {
    border-color: rgba(71, 85, 105, 0.6);
  }
</style>

<script is:inline>
  document.querySelectorAll(".proj-row").forEach(function (row) {
    var fill  = row.querySelector(".proj-fill");
    var bar   = row.querySelector(".proj-bar");
    var title = row.querySelector(".proj-title");
    var arrow = row.querySelector(".proj-arrow");
    var svg   = arrow && arrow.querySelector("svg");
    var accent = title ? getComputedStyle(title).getPropertyValue("--accent").trim() : "#53b598";

    row.addEventListener("mouseenter", function () {
      if (fill)  fill.style.transform  = "translateX(0)";
      if (bar)   bar.style.transform   = "scaleY(1)";
      if (title) title.style.color     = accent;
      if (arrow) {
        arrow.style.borderColor        = accent + "60";
        arrow.style.background         = accent + "18";
      }
      if (svg)   svg.style.color       = accent;
    });

    row.addEventListener("mouseleave", function () {
      if (fill)  fill.style.transform  = "translateX(-100%)";
      if (bar)   bar.style.transform   = "scaleY(0)";
      if (title) title.style.color     = "";
      if (arrow) { arrow.style.borderColor = ""; arrow.style.background = ""; }
      if (svg)   svg.style.color       = "";
    });
  });
</script>
