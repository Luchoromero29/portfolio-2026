---
import type { Language } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

export interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const { t } = await useTranslations(lang);

const currentYear = new Date().getFullYear();

const navLinks = [
  { key: "nav.home", href: "/", label: t("nav.home") },
  { key: "nav.projects", href: "/projects", label: t("nav.projects") },
  { key: "nav.about", href: "/#about", label: t("nav.about") },
  { key: "nav.contact", href: "/#contact", label: t("nav.contact") },
];

const socials = [
  {
    href: "https://github.com/luchoromero29",
    label: "GitHub",
    hoverClass: "hover:bg-white/10 hover:border-white/20 hover:text-white",
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    href: "https://linkedin.com/in/lucianoromerosilva",
    label: "LinkedIn",
    hoverClass: "hover:bg-blue-600/20 hover:border-blue-500/40 hover:text-blue-400",
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    href: "mailto:luchonromero@gmail.com",
    label: "Email",
    hoverClass: "hover:bg-brand-teal/15 hover:border-brand-teal/40 hover:text-brand-lime",
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
];
---

<footer class="relative bg-slate-900 dark:bg-[#0a0f1a] text-slate-400 overflow-hidden">

  <!-- Top glow line -->
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent 0%, rgba(83,181,152,0.5) 30%, rgba(200,219,135,0.5) 50%, rgba(83,181,152,0.5) 70%, transparent 100%);"></div>

  <!-- Ambient glow orbs -->
  <div class="absolute -top-32 -left-32 w-80 h-80 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(83,181,152,0.06) 0%, transparent 65%);"></div>
  <div class="absolute -bottom-20 -right-20 w-72 h-72 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(200,219,135,0.05) 0%, transparent 65%);"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">

    <!-- Main grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-14">

      <!-- Brand column -->
      <div class="md:col-span-1 space-y-5">
        <a href="/" class="inline-flex items-center gap-3 group">
          <span
            class="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-extrabold text-slate-900 shadow-lg group-hover:shadow-brand-teal/30 transition-shadow duration-300"
            style="background: linear-gradient(135deg, #c8db87, #53b598);"
          >LR</span>
          <span class="font-bold text-white text-base tracking-tight group-hover:text-brand-lime transition-colors duration-200">
            Luciano Romero
          </span>
        </a>

        <p class="text-slate-500 text-[13.5px] leading-relaxed max-w-[220px]" data-i18n="about.bio1">
          {t("about.bio1")}
        </p>

        <!-- Availability pill -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-teal/20 bg-brand-teal/5">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-brand-lime opacity-70" style="animation: pulse-slow 2.5s ease-in-out infinite;"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-lime"></span>
          </span>
          <span class="text-[11px] font-semibold text-brand-lime tracking-wide" data-i18n="footer.availableForWork">{t("footer.availableForWork")}</span>
        </div>
      </div>

      <!-- Navigation column -->
      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600 mb-5" data-i18n="footer.navigation">{t("footer.navigation")}</h4>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="group flex items-center gap-2 text-[13.5px] text-slate-500 hover:text-white transition-colors duration-200"
              >
                <span class="w-3.5 h-px bg-slate-700 group-hover:bg-brand-teal group-hover:w-4 transition-all duration-200"></span>
                <span data-i18n={link.key}>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social + stack column -->
      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600 mb-5" data-i18n="footer.connect">{t("footer.connect")}</h4>

        <!-- Social icons -->
        <div class="flex gap-2.5 mb-8">
          {socials.map((s) => (
            <a
              href={s.href}
              target={s.href.startsWith("http") ? "_blank" : undefined}
              rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
              aria-label={s.label}
              class={`w-10 h-10 rounded-xl bg-slate-800/80 border border-slate-700/60 flex items-center justify-center text-slate-500 transition-all duration-200 ${s.hoverClass}`}
              set:html={s.icon}
            />
          ))}
        </div>

        <!-- Built-with stack -->
        <div>
          <h4 class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-600 mb-3" data-i18n="footer.builtWith">{t("footer.builtWith")}</h4>
          <div class="flex flex-wrap gap-2">
            {["Astro 5", "TailwindCSS v4", "TypeScript"].map((tech) => (
              <span class="px-2.5 py-1 rounded-lg text-[11px] font-medium text-slate-400 bg-slate-800/70 border border-slate-700/50">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-800/70"></div>

    <!-- Bottom bar -->
    <div class="pt-7 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[12px] text-slate-600">
        © {currentYear} Luciano Romero.{" "}
        <span data-i18n="footer.rights">{t("footer.rights")}</span>
      </p>
      <p class="text-[12px] text-slate-600 flex items-center gap-1.5">
        <span data-i18n="footer.madeWith">{t("footer.madeWith")}</span>
        <span class="text-gradient font-semibold">Astro + Tailwind</span>
        <!-- <span>·</span>
        <span data-i18n="footer.deployedOnVercel">{t("footer.deployedOnVercel")}</span> -->
      </p>
    </div>

  </div>
</footer>
