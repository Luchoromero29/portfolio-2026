---
import type { Language } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

export interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const { t } = await useTranslations(lang);

const contactLinks = [
  {
    key: "email",
    label: t("contact.email"),
    labelKey: "contact.email",
    value: "luchonromero@gmail.com",
    description: t("contact.emailDescription"),
    descriptionKey: "contact.emailDescription",
    cta: t("contact.emailCta"),
    ctaKey: "contact.emailCta",
    href: "mailto:luchonromero@gmail.com",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    iconBg: "from-[#c8db87] to-[#53b598]",
    glow: "rgba(83,181,152,0.2)",
    accent: "#53b598",
  },
  {
    key: "github",
    label: t("contact.github"),
    labelKey: "contact.github",
    value: "@luchoromero29",
    description: t("contact.githubDescription"),
    descriptionKey: "contact.githubDescription",
    cta: t("contact.githubCta"),
    ctaKey: "contact.githubCta",
    href: "https://github.com/luchoromero29",
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
    iconBg: "from-slate-700 to-slate-800",
    glow: "rgba(100,116,139,0.2)",
    accent: "#475569",
  },
  {
    key: "linkedin",
    label: t("contact.linkedin"),
    labelKey: "contact.linkedin",
    value: "in/lucianoromerosilva",
    description: t("contact.linkedinDescription"),
    descriptionKey: "contact.linkedinDescription",
    cta: t("contact.linkedinCta"),
    ctaKey: "contact.linkedinCta",
    href: "https://linkedin.com/in/lucianoromerosilva",
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    iconBg: "from-blue-600 to-blue-700",
    glow: "rgba(37,99,235,0.2)",
    accent: "#2563eb",
  },
];

const sectionTag = t("contact.tagline");
const availabilityText = t("contact.availability");
---

<section id="contact" class="contact-shell py-28 sm:py-36 relative overflow-hidden">
  <!-- Ambient background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute -top-44 -left-44 w-130 h-130 rounded-full"
      style="background: radial-gradient(circle, rgba(83,181,152,0.14) 0%, transparent 68%);"
      data-parallax="0.06"
    ></div>
    <div
      class="absolute -bottom-40 -right-32 w-140 h-140 rounded-full"
      style="background: radial-gradient(circle, rgba(200,219,135,0.12) 0%, transparent 70%);"
      data-parallax="-0.05"
    ></div>
    <div
      class="absolute inset-0 opacity-[0.035]"
      style="background-image: radial-gradient(circle, rgba(83,181,152,0.9) 1px, transparent 1px); background-size: 32px 32px;"
    ></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1.15fr_1fr] gap-8 lg:gap-10 items-stretch">
      <!-- Editorial side -->
      <div class="reveal contact-editorial rounded-4xl p-7 sm:p-10 lg:p-12">
        <p class="eyebrow mb-4" data-i18n="contact.tagline">{sectionTag}</p>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.05] mb-5">
          <span data-i18n="contact.title">{t("contact.title")}</span>
        </h2>
        <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed max-w-xl mb-8" data-i18n="contact.subtitle">
          {t("contact.subtitle")}
        </p>

        <div class="inline-flex items-start gap-3 rounded-2xl border border-brand-teal/20 bg-brand-teal/5 dark:bg-brand-teal/10 px-4 py-4 mb-9">
          <span class="mt-1 inline-flex w-2.5 h-2.5 rounded-full bg-brand-teal shadow-[0_0_0_4px_rgba(83,181,152,0.2)]"></span>
          <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed" data-i18n="contact.availability">{availabilityText}</p>
        </div>

        <a
          href="mailto:luchonromero@gmail.com"
          class="inline-flex items-center gap-2 px-6 py-3.5 rounded-2xl bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-semibold tracking-wide hover:scale-[1.02] hover:shadow-xl transition-all duration-300"
        >
          <span data-i18n="contact.sendEmail">{t("contact.sendEmail")}</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <!-- Contact channels -->
      <div class="grid grid-cols-1 gap-4 sm:gap-5">
        {contactLinks.map((link, idx) => (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="reveal contact-card group rounded-3xl p-5 sm:p-6"
            style={`--accent: ${link.accent}; --glow: ${link.glow}; animation-delay: ${idx * 90}ms;`}
          >
            <div class="flex items-start gap-4">
              <div
                class={`relative w-14 h-14 shrink-0 rounded-2xl flex items-center justify-center text-white shadow-lg bg-linear-to-br ${link.iconBg} group-hover:scale-105 transition-transform duration-300`}
                set:html={link.icon}
              >
                <span class="contact-icon-glow"></span>
              </div>

              <div class="min-w-0 flex-1">
                <div class="flex items-center justify-between gap-3 mb-1.5">
                  <h3 class="text-base font-extrabold text-slate-900 dark:text-white tracking-tight" data-i18n={link.labelKey}>{link.label}</h3>
                  <span class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-400 dark:text-slate-500">0{idx + 1}</span>
                </div>

                <p class="text-sm font-semibold text-slate-700 dark:text-slate-200 mb-1 truncate">{link.value}</p>
                <p class="text-[13px] text-slate-500 dark:text-slate-400 leading-relaxed" data-i18n={link.descriptionKey}>{link.description}</p>

                {link.key === "email" && (
                  <button
                    type="button"
                    class="copy-email-btn mt-3 inline-flex items-center gap-1.5 rounded-lg border border-brand-teal/35 bg-brand-teal/8 px-2.5 py-1.5 text-[11px] font-semibold text-brand-teal dark:text-brand-lime hover:bg-brand-teal/15 dark:hover:bg-brand-teal/20 transition-colors duration-200"
                    data-email={link.value}
                    data-default={t("contact.copyEmail")}
                    data-copied={t("contact.copied")}
                    onclick="event.preventDefault(); event.stopPropagation();"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 10h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                    <span data-i18n="contact.copyEmail">{t("contact.copyEmail")}</span>
                  </button>
                )}

                <div class="mt-4 inline-flex items-center gap-2 text-xs font-semibold text-slate-500 dark:text-slate-400 group-hover:text-slate-700 dark:group-hover:text-slate-200 transition-colors duration-300">
                  <span data-i18n={link.ctaKey}>{link.cta}</span>
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="text-center mt-14 reveal">
      <div class="inline-flex items-center gap-2.5 px-6 py-3 rounded-2xl border border-slate-200/80 dark:border-slate-800 bg-white/85 dark:bg-slate-900/80 text-slate-500 dark:text-slate-400 text-sm shadow-sm backdrop-blur-sm">
        <span>Built with</span>
        <span class="font-bold text-gradient">Astro</span>
        <span class="text-slate-300 dark:text-slate-700">x</span>
        <span class="font-bold text-gradient">Tailwind</span>
        <span class="text-slate-300 dark:text-slate-700">x</span>
        <span>love</span>
      </div>
    </div>
  </div>

  <div id="copy-toast" class="copy-toast" role="status" aria-live="polite">
    <span data-i18n="contact.copied">{t("contact.copied")}</span>
  </div>
</section>

<style>
  .contact-shell {
    background:
      radial-gradient(ellipse at 0% 0%, rgba(83, 181, 152, 0.06), transparent 45%),
      radial-gradient(ellipse at 100% 100%, rgba(200, 219, 135, 0.08), transparent 45%),
      #f8fafc;
  }

  :global(.dark) .contact-shell {
    background:
      radial-gradient(ellipse at 0% 0%, rgba(83, 181, 152, 0.09), transparent 45%),
      radial-gradient(ellipse at 100% 100%, rgba(200, 219, 135, 0.08), transparent 45%),
      #020617;
  }

  .contact-editorial {
    border: 1px solid rgba(148, 163, 184, 0.2);
    background:
      linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.78));
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(8px);
  }

  :global(.dark) .contact-editorial {
    border-color: rgba(71, 85, 105, 0.45);
    background:
      linear-gradient(160deg, rgba(15, 23, 42, 0.84), rgba(15, 23, 42, 0.68));
    box-shadow: 0 24px 60px rgba(2, 6, 23, 0.45);
  }

  .contact-card {
    border: 1px solid rgba(226, 232, 240, 0.9);
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.35s ease, border-color 0.35s ease;
  }

  :global(.dark) .contact-card {
    border-color: rgba(71, 85, 105, 0.5);
    background: rgba(15, 23, 42, 0.72);
    box-shadow: 0 10px 28px rgba(2, 6, 23, 0.35);
  }

  .contact-card:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--accent) 35%, white);
    box-shadow: 0 18px 38px var(--glow);
  }

  .contact-icon-glow {
    position: absolute;
    inset: -4px;
    border-radius: 1rem;
    background: var(--glow);
    filter: blur(10px);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .contact-card:hover .contact-icon-glow {
    opacity: 1;
  }

  .copy-email-btn.is-copied {
    background: rgba(83, 181, 152, 0.22);
    border-color: rgba(83, 181, 152, 0.65);
    color: #0f766e;
  }

  :global(.dark) .copy-email-btn.is-copied {
    color: #bef264;
  }

  .copy-toast {
    position: fixed;
    left: 50%;
    bottom: 22px;
    transform: translateX(-50%) translateY(10px);
    opacity: 0;
    pointer-events: none;
    z-index: 70;
    border-radius: 9999px;
    border: 1px solid rgba(83, 181, 152, 0.4);
    background: rgba(15, 23, 42, 0.92);
    color: #e2e8f0;
    padding: 0.45rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .copy-toast.is-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 1023px) {
    .contact-editorial {
      border-radius: 1.5rem;
    }
  }
</style>

<script is:inline>
  (function () {
    var toast = document.getElementById("copy-toast");

    function copyText(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text);
      }

      return new Promise(function (resolve, reject) {
        try {
          var temp = document.createElement("textarea");
          temp.value = text;
          temp.setAttribute("readonly", "");
          temp.style.position = "absolute";
          temp.style.left = "-9999px";
          document.body.appendChild(temp);
          temp.select();
          document.execCommand("copy");
          document.body.removeChild(temp);
          resolve();
        } catch (err) {
          reject(err);
        }
      });
    }

    function showToast() {
      if (!toast) return;
      toast.classList.add("is-visible");
      clearTimeout(showToast._timer);
      showToast._timer = setTimeout(function () {
        toast.classList.remove("is-visible");
      }, 1300);
    }

    showToast._timer = null;

    document.querySelectorAll(".copy-email-btn").forEach(function (btn) {
      btn.addEventListener("click", function (event) {
        event.preventDefault();
        event.stopPropagation();

        var email = btn.getAttribute("data-email") || "";
        var i18n = window.__i18next;
        var defaultText = i18n ? i18n.t("contact.copyEmail") : (btn.getAttribute("data-default") || "Copy email");
        var copiedText = i18n ? i18n.t("contact.copied") : (btn.getAttribute("data-copied") || "Copied");
        var label = btn.querySelector("span");
        if (!email || !label) return;

        copyText(email)
          .then(function () {
            label.textContent = copiedText;
            btn.classList.add("is-copied");
            showToast();
            setTimeout(function () {
              label.textContent = defaultText;
              btn.classList.remove("is-copied");
            }, 1400);
          })
          .catch(function () {
            label.textContent = defaultText;
            btn.classList.remove("is-copied");
          });
      });
    });
  })();
</script>
