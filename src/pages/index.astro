---
import About from "../components/sections/About.astro";
import Contact from "../components/sections/Contact.astro";
import Hero from "../components/sections/Hero.astro";
import ProjectsPreview from "../components/sections/ProjectsPreview.astro";
import Skills from "../components/sections/Skills.astro";
import Footer from "../components/ui/Footer.astro";
import Navbar from "../components/ui/Navbar.astro";
import type { Language } from "../i18n/utils";
import Layout from "../layouts/Layout.astro";

const lang: Language = "es";
---

<Layout
  title="Luciano Romero — Software Engineer"
  description="Portfolio of Luciano Romero, Software Engineer specializing in modern web development with TypeScript, Node.js, and cloud technologies."
  lang={lang}
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />

  <main>
    <Hero lang={lang} />
    <About lang={lang} />
    <Skills lang={lang} />
    <ProjectsPreview lang={lang} />
    <Contact lang={lang} />
  </main>

  <Footer lang={lang} />
</Layout>
